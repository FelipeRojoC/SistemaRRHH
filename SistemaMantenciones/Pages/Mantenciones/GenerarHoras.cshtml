@page
@model SistemaMantenciones.Pages.Mantenciones.GenerarHorasModel
@{
    ViewData["Title"] = "Exportar Horas de Trabajo";
}

<div class="container mt-4">
    <h2>Exportar Horas de Trabajo</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>¡Éxito!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>¡Error!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <h5 class="card-title fw-bold mb-3 text-primary">Resumen de Trabajo por Mecánico</h5>
            <p class="text-muted">
                La tabla a continuación consolida la suma total de horas trabajadas por cada mecánico (agrupadas por su RUT) en base a las mantenciones registradas en el sistema.
            </p>

            <table class="table table-striped table-bordered mt-3 text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>RUT del Mecánico</th>
                        <th>Cantidad de Mantenciones Realizadas</th>
                        <th>Total de Horas Acumuladas</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.HorasConsolidadas != null && Model.HorasConsolidadas.Any())
                    {
                        foreach (var item in Model.HorasConsolidadas)
                        {
                            <tr>
                                <td class="fw-bold">@item.Rut</td>
                                <td>@item.CantidadServicios</td>
                                <td>
                                    <span class="badge bg-success fs-6">@item.TotalHoras hrs</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted p-4">
                                No se han registrado mantenciones en el sistema.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (Model.HorasConsolidadas != null && Model.HorasConsolidadas.Any())
            {
                <div class="mt-4 text-end">
                    <form method="post" asp-page-handler="Exportar">
                        <button type="submit" class="btn btn-warning btn-lg fw-bold text-dark shadow-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-box-arrow-right me-2" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M10.146 4.646a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L12.793 8l-2.647-2.646a.5.5 0 0 1 0-.708z"/>
                                <path fill-rule="evenodd" d="M2 13.5a.5.5 0 0 1-.5-.5V3a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1H3v9h4a.5.5 0 0 1 0 1H2z"/>
                            </svg>
                            Exportar Horas a Recursos Humanos
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
