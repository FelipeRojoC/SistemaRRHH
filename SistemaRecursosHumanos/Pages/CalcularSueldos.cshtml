@page
@model SistemaRRHH.Pages.CalcularSueldosModel
@{
    ViewData["Title"] = "Cálculo de Sueldos";
}

<div class="container mt-4">
    <h2>Cálculo Mensual de Remuneraciones</h2>
    <hr />
    <div class="alert alert-info">
        <strong>Integración:</strong> Los datos de horas trabajadas se están leyendo en tiempo real desde el archivo <code>horas.json</code> generado por el sistema de Mantención.
    </div>

    <table class="table table-striped table-bordered mt-3 text-center">
        <thead class="table-dark">
            <tr>
                <th>RUT</th>
                <th>Nombre</th>
                <th>Sueldo Base</th>
                <th>Horas Trabajadas</th>
                <th>Pago Variable</th>
                <th>Sueldo Total a Pagar</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var liq in Model.Liquidaciones)
            {
                <tr class="@(liq.TieneRegistroEnTrabajadores ? "" : "table-warning")">
                    <td>@liq.Rut</td>
                    <td>@liq.Nombre</td>
                    <td>$@liq.SueldoBase.ToString("N0")</td>
                    <td><span class="badge bg-secondary">@liq.HorasTrabajadas hrs</span></td>
                    <td>$@liq.MontoVariable.ToString("N0")</td>
                    <td class="fw-bold text-success fs-5">$@liq.SueldoTotal.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>

    <p class="text-muted mt-2 mb-0">
        Las filas en amarillo indican RUT presentes en <code>horas.json</code> pero aún no registrados en la tabla de trabajadores.
    </p>
</div>