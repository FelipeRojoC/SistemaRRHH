@page
@model SistemaArriendos.Pages.Arriendos.IndexModel
@{
    ViewData["Title"] = "Lista de Arriendos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Registro de Arriendos</h2>
        <a asp-page="./Crear" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-circle-fill me-1" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM8.5 4.5a.5.5 0 0 0-1 0v3h-3a.5.5 0 0 0 0 1h3v3a.5.5 0 0 0 1 0v-3h3a.5.5 0 0 0 0-1h-3v-3z"/>
            </svg>
            Nuevo Arriendo
        </a>
    </div>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-striped table-bordered mt-3 text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Vehículo</th>
                <th>Cliente</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Precio Diario</th>
                <th>Total</th>
                <th>Estado Vehículo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Arriendos != null && Model.Arriendos.Any())
            {
                foreach (var item in Model.Arriendos)
                {
                    string badgeColor = item.CodigoVehiculoNavigation.Estado switch
                    {
                        "Activo" => "bg-success",
                        "Arrendado" => "bg-primary",
                        "En Mantencion" => "bg-warning text-dark",
                        "De Baja" => "bg-danger",
                        _ => "bg-secondary"
                    };

                    bool puedeDevolver = item.CodigoVehiculoNavigation.Estado == "Arrendado";

                    <tr>
                        <td class="fw-bold">@item.Id</td>
                        <td>
                            <strong>@item.CodigoVehiculo</strong><br />
                            <small class="text-muted">@item.CodigoVehiculoNavigation.Marca @item.CodigoVehiculoNavigation.Modelo (@item.CodigoVehiculoNavigation.Patente)</small>
                        </td>
                        <td>
                            <strong>@item.RutClienteNavigation.Nombre</strong><br />
                            <small class="text-muted">@item.RutCliente</small>
                        </td>
                        <td>@item.FechaInicio.ToString("dd-MM-yyyy")</td>
                        <td>@item.FechaFin.ToString("dd-MM-yyyy")</td>
                        <td>$@item.PrecioDiario.ToString("N0")</td>
                        <td class="fw-bold text-success">$@item.PrecioTotal.ToString("N0")</td>
                        <td><span class="badge @badgeColor">@item.CodigoVehiculoNavigation.Estado</span></td>
                        <td>
                            @if (puedeDevolver)
                            {
                                <form method="post" asp-page="./Devolver" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('¿Confirmar devolución del vehículo? Su estado volverá a Activo.');">Devolver</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted p-4">
                        Aún no se han registrado arriendos. ¡Crea el primero!
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
