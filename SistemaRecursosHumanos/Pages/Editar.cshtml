@page
@model SistemaRRHH.Pages.EditarModel
@{
	ViewData["Title"] = "Editar Trabajador";
}

<div class="container mt-4">
	<h2>Modificar Datos del Trabajador</h2>
	<hr />

	<div class="card">
		<div class="card-body">
			<form method="post">
				<div class="mb-3">
					<label class="form-label">RUT</label>
					<input asp-for="Trabajador.Rut" class="form-control" readonly />
				</div>

				<div class="mb-3">
					<label class="form-label">Nombre</label>
					<input asp-for="Trabajador.Nombre" class="form-control" required />
				</div>

				<div class="mb-3">
					<label class="form-label">Sueldo Base ($)</label>
					<input asp-for="Trabajador.SueldoBase" class="form-control" type="number" required />
				</div>

				<div class="mb-3">
					<label class="form-label">Valor Hora ($)</label>
					<input asp-for="Trabajador.ValorHora" class="form-control" type="number" required />
				</div>

				<button type="submit" class="btn btn-success">Guardar Cambios</button>
				<a asp-page="./Trabajadores" class="btn btn-secondary">Cancelar</a>
			</form>
		</div>
	</div>
</div>
