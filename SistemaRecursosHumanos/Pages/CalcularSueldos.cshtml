@page
@model SistemaRRHH.Pages.CalcularSueldosModel
@{
    ViewData["Title"] = "Cálculo de Sueldos";
}

<div class="container mt-4">
    <h2>Cálculo Mensual de Remuneraciones</h2>
    <hr />
    <div class="alert alert-info">
        <strong>Integración:</strong> Los datos de horas trabajadas se están leyendo en tiempo real desde el archivo <code>horas.json</code> generado por el sistema de Mantención.
    </div>

    @if (Model.Liquidaciones == null || !Model.Liquidaciones.Any())
    {
        <div class="alert alert-warning text-center mt-4 p-4 border-0 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-info-circle text-warning mb-2" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
            </svg>
            <h5 class="fw-bold mt-2">Sin Registros Disponibles</h5>
            <p class="text-muted mb-0">
                No se han encontrado trabajadores contratados ni horas procesadas en este momento. Asegúrate de registrar mecánicos en "Trabajadores" e ingresar y exportar sus mantenciones desde el Sistema de Mantenciones.
            </p>
        </div>
    }
    else
    {
        <table class="table table-striped table-bordered mt-3 text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th>RUT</th>
                    <th>Nombre</th>
                    <th>Sueldo Base</th>
                    <th>Horas Trabajadas</th>
                    <th>Pago Variable</th>
                    <th>Sueldo Total a Pagar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var liq in Model.Liquidaciones)
                {
                    <tr class="@(liq.TieneRegistroEnTrabajadores ? "" : "table-warning")">
                        <td class="fw-bold">@liq.Rut</td>
                        <td>@liq.Nombre</td>
                        <td>$@liq.SueldoBase.ToString("N0")</td>
                        <td><span class="badge bg-secondary px-3">@liq.HorasTrabajadas hrs</span></td>
                        <td>$@liq.MontoVariable.ToString("N0")</td>
                        <td class="fw-bold text-success fs-5">$@liq.SueldoTotal.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.Liquidaciones.Any(l => !l.TieneRegistroEnTrabajadores))
        {
            <p class="text-muted mt-2 mb-0">
                <span class="badge bg-warning text-dark me-1">Atención</span> Las filas en amarillo indican RUTs presentes en <code>horas.json</code> pero que aún no han sido registrados en la tabla de trabajadores.
            </p>
        }
    }
</div>