@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio - Sistema de Recursos Humanos";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10 text-center">
            <h1 class="display-4 fw-bold text-primary mb-3">Sistema de Recursos Humanos</h1>
            <p class="lead text-muted mb-4">
                Administración y registro de mecánicos técnicos, contratos de sueldo base, valor de hora y cálculo consolidado de liquidaciones mensuales en base a horas integradas.
            </p>
            <hr class="my-4" />
        </div>
    </div>

    <div class="row mt-4 g-4 justify-content-center">
        <!-- Tarjeta Gestión de Trabajadores -->
        <div class="col-md-5">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="mb-3 text-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-people" viewBox="0 0 16 16">
                            <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8Zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 1 1 1 1 1h4a.5.5 0 0 0 0-1H1.35c.002-.153.111-.635.568-1.172C2.413 11.18 3.543 10.5 5 10.5c.372 0 .724.04 1.05.12V9.28ZM5 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm2-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                        </svg>
                    </div>
                    <h5 class="card-title fw-bold">Gestión de Mecánicos</h5>
                    <p class="card-text text-muted">Ingresa nuevos técnicos, modifica sus datos contractuales, configura su sueldo base y el valor asignado por hora de trabajo.</p>
                    <a asp-page="/Trabajadores" class="btn btn-outline-primary mt-3">Administrar Trabajadores</a>
                </div>
            </div>
        </div>

        <!-- Tarjeta Cálculo de Remuneraciones -->
        <div class="col-md-5">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="mb-3 text-success">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-calculator" viewBox="0 0 16 16">
                            <path d="M12 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h8zM4 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H4z"/>
                            <path d="M4 2.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm-6 3a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm-6 3a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5z"/>
                        </svg>
                    </div>
                    <h5 class="card-title fw-bold">Cálculo de Remuneraciones</h5>
                    <p class="card-text text-muted">Procesa y visualiza las liquidaciones del mes leyendo en tiempo real las horas de mantención consolidadas en el archivo de integración.</p>
                    <a asp-page="/CalcularSueldos" class="btn btn-outline-success mt-3">Calcular Sueldos</a>
                </div>
            </div>
        </div>
    </div>
</div>
