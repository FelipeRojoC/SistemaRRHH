@page
@model SistemaArriendos.Pages.Vehiculos.IndexModel
@{
    ViewData["Title"] = "Disponibilidad de Flota";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Disponibilidad de Flota</h2>
        <a asp-page="/Arriendos/Crear" class="btn btn-primary">Registrar Arriendo</a>
    </div>
    <p class="text-muted small">Solo los vehículos en estado <span class="badge bg-success">Activo</span> pueden ser arrendados. El ingreso/modificación de vehículos se realiza desde el Sistema de Mantenciones.</p>
    <hr />

    <table class="table table-striped table-bordered mt-3 text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>Código</th>
                <th>Patente</th>
                <th>Marca</th>
                <th>Modelo</th>
                <th>Tipo</th>
                <th>Kilometraje</th>
                <th>Estado</th>
                <th>Precio Diario</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Vehiculos != null && Model.Vehiculos.Any())
            {
                foreach (var item in Model.Vehiculos)
                {
                    string badgeColor = item.Estado switch
                    {
                        "Activo" => "bg-success",
                        "Arrendado" => "bg-primary",
                        "En Mantencion" => "bg-warning text-dark",
                        "De Baja" => "bg-danger",
                        _ => "bg-secondary"
                    };

                    <tr>
                        <td class="fw-bold">@item.Codigo</td>
                        <td>@item.Patente</td>
                        <td>@item.Marca</td>
                        <td>@item.Modelo</td>
                        <td>@item.Tipo</td>
                        <td>@item.Kilometraje.ToString("N0") km</td>
                        <td><span class="badge @badgeColor">@item.Estado</span></td>
                        <td class="fw-bold text-success">$@item.PrecioArriendoDiario.ToString("N0")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted p-4">
                        No hay vehículos registrados. Ingrésalos desde el Sistema de Mantenciones.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
